# ---- Server ----
PORT=8001
# Comma-separated allowed origins (your frontend URL). Blank = reflect request origin.
CORS_ORIGINS="http://localhost:3000"

# ---- Supabase ----
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-or-publishable-key"          # public key, used to verify user tokens
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"  # SECRET — backend only, bypasses RLS

# The user whose email matches this is auto-promoted to admin on first login.
ADMIN_EMAIL="dr.admin@pacopilot.health"

# ---- Your own LLM key (Anthropic Claude — reasoning + vision OCR) ----
ANTHROPIC_API_KEY="sk-ant-your-key-here"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
