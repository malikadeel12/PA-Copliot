PORT=8001
CORS_ORIGINS=""

SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-or-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

ADMIN_EMAIL="admin@example.com"

ANTHROPIC_API_KEY="sk-ant-REPLACE-WITH-YOUR-KEY"
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# Google Document AI (OCR). Either set GCP_SERVICE_ACCOUNT_JSON to the full service-account
# JSON string (recommended on Render/Vercel), OR set GCP_KEY_FILE to a local JSON key path.
GCP_SERVICE_ACCOUNT_JSON=""
GCP_KEY_FILE="./gcp-service-account.json"
DOCUMENT_AI_LOCATION="us"
DOCUMENT_AI_PROCESSOR_ID="your-document-ai-processor-id"
